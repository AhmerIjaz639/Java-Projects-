<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.planner.MoodSuggestionController"
            prefWidth="700" prefHeight="520"
            style="-fx-background-color: linear-gradient(to bottom, #031b77, #064054, #027eb4); -fx-padding: 20;">

    <!-- Top Section: Cinematic Title and Back Button -->
    <top>
        <VBox spacing="15" alignment="CENTER_LEFT">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button fx:id="BackButton" text="←"
                        style="-fx-font-size: 20px; -fx-background-color: transparent;
                               -fx-text-fill: orange; -fx-cursor: hand;
                               -fx-border-color: orange; -fx-border-radius: 5;
                               -fx-padding: 4 12; -fx-background-radius: 5;"
                        onAction="#handleBackButton" />
                <Label text=" Mood-Based Task Suggestion"
                       style="-fx-font-size: 24px; -fx-font-weight: bold;
                              -fx-text-fill: linear-gradient(to right, #FFA500, #FFD580);" />
            </HBox>
        </VBox>
    </top>

    <!-- Center Section: Mood Selection Panel -->
    <center>
        <VBox spacing="25" alignment="CENTER"
              style="-fx-background-color: rgba(255, 255, 255, 0.08);
                     -fx-padding: 40; -fx-background-radius: 12;">

            <Label text="What's your vibe right now?"
                   style="-fx-font-size: 18px; -fx-text-fill: white; -fx-font-style: italic;" />

            <ComboBox fx:id="moodComboBox" promptText="Choose your mood..." prefWidth="260"
                      style="-fx-background-color: white; -fx-border-radius: 6; -fx-padding: 5;" />


            <Button fx:id="suggestButton" text=" Suggest Me Something"
                    onAction="#handleMoodSuggestion"
                    style="-fx-background-color: #00BFFF; -fx-text-fill: white;
               -fx-font-weight: bold; -fx-background-radius: 10;
               -fx-padding: 10 20; -fx-font-size: 14px;
               -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 5, 0.3, 0, 2);
               -fx-cursor: hand;" />

        </VBox>
    </center>


    <bottom>
        <TextArea fx:id="suggestionArea" editable="false" wrapText="true"
                  prefHeight="220"
                  style="-fx-background-color: white; -fx-text-fill: #2C3E50;
                         -fx-font-size: 15px; -fx-border-color: #00BFFF;
                         -fx-border-radius: 10; -fx-background-radius: 10;
                         -fx-padding: 12;" />
    </bottom>

</BorderPane>
