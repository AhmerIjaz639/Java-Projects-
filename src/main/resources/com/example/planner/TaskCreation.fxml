<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.planner.TaskCreationController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color:linear-gradient(to bottom, #031b77, #064054, #027eb4);
">

    <!-- Top Bar with Back Button -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-padding: 15 20; -fx-background-color: rgba(0, 0, 0, 0.2);">
            <Button fx:id="BackButton" text="← Back"
                    style="-fx-font-size: 18px; -fx-background-color: transparent;
                           -fx-text-fill: #FFA500; -fx-font-weight: bold; -fx-cursor: hand;"
                    onAction="#handleBackButton"/>
        </HBox>
    </top>

    <!-- Center Content -->
    <center>
        <VBox spacing="20" alignment="CENTER" style="-fx-padding: 30;">

            <fx:define>
                <ToggleGroup fx:id="taskTypeGroup"/>
            </fx:define>

            <Label text="Create New Task"
                   style="-fx-font-size: 30px; -fx-font-family: 'Segoe UI Semibold';
                          -fx-text-fill: #FFFFFF; -fx-effect: dropshadow(gaussian, #000000, 2, 0.5, 0, 1);"/>

            <!-- Task Type Toggle -->
            <HBox spacing="25" alignment="CENTER"
                  style="-fx-background-color: #120283; -fx-padding: 15;
                         -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, black, 10, 0, 0, 2);">
                <RadioButton fx:id="examRadio" text="Exam" onMouseClicked="#onTaskTypeSelected"
                             toggleGroup="$taskTypeGroup"
                             style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px;"/>
                <RadioButton fx:id="assignmentRadio" text="Assignment" onMouseClicked="#onTaskTypeSelected"
                             toggleGroup="$taskTypeGroup"
                             style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px;"/>
                <RadioButton fx:id="generalRadio" text="General" onMouseClicked="#onTaskTypeSelected"
                             toggleGroup="$taskTypeGroup"
                             style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px;"/>
            </HBox>

            <!-- Common Task Inputs -->
            <VBox spacing="12" alignment="CENTER">
                <TextField fx:id="taskNameField" promptText="Task Name"
                           style="-fx-pref-width: 320; -fx-background-radius: 8; -fx-padding: 10;"/>
                <HBox spacing="10">
                    <DatePicker fx:id="dueDatePicker" promptText="Due Date"
                                style="-fx-pref-width: 160; -fx-background-radius: 8;"/>
                    <TextField fx:id="dueTimeField" promptText="hh:mm AM/PM"
                               style="-fx-pref-width: 140; -fx-background-radius: 8;"/>
                </HBox>
                <TextField fx:id="priorityField" promptText="Priority (High / Medium / Low)"
                           style="-fx-pref-width: 320; -fx-background-radius: 8;"/>
            </VBox>

            <!-- Exam Specific Fields -->
            <VBox fx:id="examFields" spacing="10" alignment="CENTER" visible="false" managed="false">
                <TextField fx:id="subjectField" promptText="Subject Name" style="-fx-pref-width: 320;"/>
                <HBox spacing="10">
                    <DatePicker fx:id="examDatePicker" promptText="Exam Date"
                                style="-fx-pref-width: 160;"/>
                    <TextField fx:id="examTimeField" promptText="hh:mm AM/PM"
                               style="-fx-pref-width: 140;"/>
                </HBox>
            </VBox>

            <!-- Assignment Specific Fields -->
            <VBox fx:id="assignmentFields" spacing="10" alignment="CENTER" visible="false" managed="false">
                <TextField fx:id="courseField" promptText="Course Name" style="-fx-pref-width: 320;"/>
                <HBox spacing="10">
                    <DatePicker fx:id="submissionDatePicker" promptText="Submission Date"
                                style="-fx-pref-width: 160;"/>
                    <TextField fx:id="submissionTimeField" promptText="hh:mm AM/PM"
                               style="-fx-pref-width: 140;"/>
                </HBox>
            </VBox>

            <!-- General Task Fields -->
            <VBox fx:id="generalFields" spacing="10" alignment="CENTER" visible="false" managed="false">
                <Label text="Description:" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <TextArea fx:id="descriptionField"
                          promptText="Describe the task..."
                          prefRowCount="4" wrapText="true"
                          style="-fx-pref-width: 320; -fx-background-radius: 8;"/>
            </VBox>

            <!-- Controls -->
            <HBox spacing="15" alignment="CENTER">
                <CheckBox fx:id="isCompleteCheck" text="Mark as Completed" style="-fx-text-fill: white;"/>

                <Button fx:id="saveTaskButton" text="Save Task" onAction="#onSaveTask"
                        style="-fx-background-color: #FFA500;
                               -fx-text-fill: #1A1A1A;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-padding: 8 16;"/>

                <Button fx:id="viewTasksButton" text="View All Tasks" onAction="#onViewTasks"
                        style="-fx-background-color: #00BFFF;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-padding: 8 16;"/>
            </HBox>

        </VBox>
    </center>
</BorderPane>
