<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="400" prefWidth="600" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.planner.ViewNotesController" style="-fx-background-color: #f0f4f8;">
    <left>
        <VBox spacing="10" BorderPane.alignment="CENTER" style="-fx-background-color: #fc8f00; -fx-padding: 10;">
            <Label alignment="CENTER" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" text="Notes List" />
            <ListView fx:id="notesListView" prefWidth="200" />
        </VBox>
    </left>

    <center>
        <VBox spacing="10" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>
            <Label contentDisplay="CENTER" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #090dfa;" text="Note Details" />
            <TextArea fx:id="notesArea" editable="false" prefHeight="350" wrapText="true" style="-fx-border-color: #fc8f00; -fx-border-width: 2; -fx-background-color: white;" />
        </VBox>
    </center>
</BorderPane>

