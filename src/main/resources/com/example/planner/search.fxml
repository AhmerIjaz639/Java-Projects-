<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.planner.SearchController"
            style="-fx-background-color: #f4f6fb;">

    <top>
        <VBox spacing="10" style="-fx-background-color: #003366; -fx-padding: 15;">
            <Label text="Search Tasks"
                   style="-fx-font-size: 20px; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </VBox>
    </top>
    <HBox alignment="CENTER_LEFT" spacing="10" prefWidth="100">
        <Button fx:id="backButton" text="←"
                style="-fx-font-size: 20px; -fx-background-color: transparent; -fx-text-fill: #FFA500; -fx-cursor: hand;"
                onAction="#handleBackButton"/>
        <Label text="Back To DashBoard" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #FFA500;" />
    </HBox>
    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <HBox spacing="10">
                <ComboBox fx:id="searchTypeCombo" promptText="Search By" prefWidth="150"/>
                <TextField fx:id="searchField" promptText="Enter value" prefWidth="200" />
                <DatePicker fx:id="datePicker" visible="false"/>
                <Button text="Search" onAction="#handleSearch"
                        style="-fx-background-color: #0077cc; -fx-text-fill: white; -fx-background-radius: 5;"/>
            </HBox>

            <TableView fx:id="resultTable" prefHeight="300">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="nameColumn" text="Name" prefWidth="150"/>
                    <TableColumn fx:id="priorityColumn" text="Priority" prefWidth="100"/>
                    <TableColumn fx:id="dueDateColumn" text="Due Date" prefWidth="150"/>
                    <TableColumn fx:id="completeColumn" text="Complete" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>
